    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/swagger-ui-express": "^4.1.6",
    "prisma": "^5.17.0",
    "tsx": "^4.16.2"
  }
